# Copiá este archivo a ".env" y completá con tus valores reales.
# El archivo ".env" NUNCA se sube a git (ver .gitignore).

# Credenciales de tu app en Mercado Libre Developers (Application Manager)
ML_CLIENT_ID=
ML_CLIENT_SECRET=

# Debe coincidir EXACTO (incluido el /auth) con el Redirect URI configurado
# en el panel de ML Developers -> tu app -> Redirect URI.
ML_REDIRECT_URI=https://app.andesnumismatica.cl/auth/callback

# Tu user_id de vendedor en MLA (lo confirmamos antes: 82640038)
ML_SELLER_USER_ID=82640038

# Puerto en el que corre el backend localmente
PORT=3001

# URL del frontend, para configurar CORS (en local, típicamente Vite en 5173)
FRONTEND_ORIGIN=http://localhost:5173
